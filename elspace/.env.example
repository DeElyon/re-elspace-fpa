# .env.example

# App Configuration
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api
WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Database
DATABASE_URL="postgresql://elspace:elspace_password@localhost:5432/elspace"

# Redis
REDIS_URL="redis://default:elspace_redis@localhost:6379"

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="your-super-secret-nextauth-key-change-in-production"
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"
REFRESH_TOKEN_EXPIRES_IN="30d"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@elspace.tech
SMTP_PASS="your-app-specific-password"

# Email (Resend - Alternative)
RESEND_API_KEY=""

# Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Storage (Uploadthing)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Payments (Stripe)
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Payments (Korapay)
KORAPAY_CHECKOUT_URL="https://checkout.korapay.com/pay/VZBklOmLoiuRiu3"

# Payments (PayPal)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE=sandbox

# Video (Daily.co)
DAILY_API_KEY=""
DAILY_API_URL=https://api.daily.co/v1

# Analytics
MIXPANEL_TOKEN=""
POSTHOG_API_KEY=""
POSTHOG_HOST=https://app.posthog.com

# Feature Flags
ENABLE_CRYPTO_PAYMENTS=false
ENABLE_VIDEO_RECORDING=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_TWO_FACTOR_AUTH=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Cache
CACHE_TTL=3600
