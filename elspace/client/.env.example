# ============================================
# APP CONFIGURATION
# ============================================
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5000

# ============================================
# AUTHENTICATION
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-nextauth-key-change-in-production
NEXT_PUBLIC_JWT_EXPIRATION=7d

# OAuth Providers
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=your_linkedin_client_id

# ============================================
# PAYMENTS
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
NEXT_PUBLIC_PAYPAL_MODE=sandbox

# Crypto
NEXT_PUBLIC_CRYPTO_ENABLED=false
NEXT_PUBLIC_CRYPTO_NETWORK=mainnet

# ============================================
# FILE UPLOAD
# ============================================
NEXT_PUBLIC_UPLOAD_MAX_SIZE=10485760
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ============================================
# VIDEO CONFERENCING
# ============================================
NEXT_PUBLIC_VIDEO_PROVIDER=daily
NEXT_PUBLIC_DAILY_CO_API_KEY=your_daily_co_api_key
NEXT_PUBLIC_DAILY_API_URL=https://api.daily.co/v1

# ============================================
# ANALYTICS & TRACKING
# ============================================
NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# ============================================
# FEATURE FLAGS
# ============================================
NEXT_PUBLIC_ENABLE_CRYPTO_PAYMENTS=false
NEXT_PUBLIC_ENABLE_SESSIONS=true
NEXT_PUBLIC_ENABLE_COMMUNITIES=true
NEXT_PUBLIC_ENABLE_DISPUTES=true
NEXT_PUBLIC_ENABLE_MESSAGING=true
NEXT_PUBLIC_ENABLE_SOCIAL_FEED=true
NEXT_PUBLIC_ENABLE_VIDEO_RECORDING=true

# ============================================
# UI & UX
# ============================================
NEXT_PUBLIC_TOAST_POSITION=top-right
NEXT_PUBLIC_TOAST_DURATION=5000
NEXT_PUBLIC_ENABLE_ANIMATIONS=true

# ============================================
# DEVELOPER
# ============================================
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=info
