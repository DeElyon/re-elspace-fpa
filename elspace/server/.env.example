# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000
HOST=localhost
APP_URL=http://localhost:5000

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/elspace"
DATABASE_POOL_SIZE=20
DATABASE_POOL_TIMEOUT=30000

# Prisma
PRISMA_CLIENT_ENGINE_TYPE=binary

# ============================================
# REDIS (Cache & Sessions)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20

# ============================================
# DATABASE ALTERNATIVES (Optional)
# ============================================
# MONGODB_URI=mongodb://localhost:27017/elspace
# MONGODB_POOL_SIZE=20

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
REFRESH_TOKEN_EXPIRES_IN=30d

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Passport
SESSION_SECRET=your-session-secret-change-in-production
SESSION_TIMEOUT=3600000

# ============================================
# CORS & NETWORK
# ============================================
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_MAX_AGE=86400

# WebSocket
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_PATH=/socket.io

# ============================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM_EMAIL=noreply@elspace.io
SMTP_FROM_NAME=Elspace

# Email Templates
EMAIL_TEMPLATE_DIR=./templates/emails

# ============================================
# FILE STORAGE (Cloudinary)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=elspace

# Alternative: Uploadthing or S3
# UPLOADTHING_SECRET=your_uploadthing_secret
# AWS_S3_BUCKET=your_bucket_name
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ============================================
# PAYMENTS
# ============================================

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_API_VERSION=2024-04-10

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
PAYPAL_API_URL=https://api.sandbox.paypal.com

# Crypto
CRYPTO_ENABLED=false
CRYPTO_NETWORKS=ethereum,polygon,solana
ETHEREUM_RPC_URL=https://rpc.sepolia.org
POLYGON_RPC_URL=https://rpc-mumbai.maticvigil.com

# ============================================
# VIDEO CONFERENCING (Daily.co)
# ============================================
DAILY_API_KEY=your_daily_co_api_key
DAILY_API_URL=https://api.daily.co/v1
DAILY_ROOM_EXPIRATION_HOURS=24
DAILY_ENABLE_RECORDING=true
DAILY_ENABLE_TRANSCRIPTION=false

# Alternative video providers
# ZOOM_CLIENT_ID=your_zoom_client_id
# ZOOM_CLIENT_SECRET=your_zoom_client_secret
# WHEREBY_API_KEY=your_whereby_api_key

# ============================================
# ANALYTICS & MONITORING
# ============================================
MIXPANEL_TOKEN=your_mixpanel_token
POSTHOG_API_KEY=your_posthog_key
SENTRY_DSN=your_sentry_dsn

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_FILE_DIR=./logs
LOG_MAX_FILE_SIZE=10m
LOG_MAX_FILES=10

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# ============================================
# BACKGROUND JOBS (BullMQ)
# ============================================
QUEUE_CONCURRENCY=10
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=5000

# ============================================
# NOTIFICATIONS
# ============================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false

# Twilio (SMS)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# Firebase Cloud Messaging (Push)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_CRYPTO_PAYMENTS=false
ENABLE_SESSIONS=true
ENABLE_COMMUNITIES=true
ENABLE_DISPUTES=true
ENABLE_MESSAGING=true
ENABLE_SOCIAL_FEED=true
ENABLE_VIDEO_RECORDING=true
ENABLE_ESCROW=true
ENABLE_INVOICING=true

# ============================================
# ADMIN & MODERATION
# ============================================
ADMIN_EMAIL=admin@elspace.io
ADMIN_PANEL_ENABLED=true
ENABLE_MODERATION_QUEUE=true
ENABLE_CONTENT_MODERATION=true
MODERATION_API_KEY=your_moderation_api_key

# ============================================
# SCHEDULED JOBS (Cron)
# ============================================
ENABLE_DAILY_STANDUP=true
ENABLE_PAYMENT_REMINDERS=true
ENABLE_DISPUTE_ESCALATION=true
ENABLE_CLEANUP_JOBS=true

# ============================================
# TIMEZONE
# ============================================
TZ=UTC

# ============================================
# EXTERNAL SERVICES
# ============================================
# Slack notifications
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Discord alerts
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# SendGrid (alternative email provider)
# SENDGRID_API_KEY=your_sendgrid_api_key

# Twilio SendGrid
# TWILIO_SENDGRID_API_KEY=your_sendgrid_api_key

# ============================================
# DEVELOPER & DEBUG
# ============================================
DEBUG_MODE=false
DEBUG_SQL=false
ENABLE_SWAGGER=true
SWAGGER_URL=/api/docs

# ============================================
# SECURITY
# ============================================
BCRYPT_ROUNDS=10
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# Two-Factor Authentication
TWO_FACTOR_ENABLED=true
TWO_FACTOR_WINDOW=30

# Rate limiting by IP
IP_RATE_LIMIT_ENABLED=true
TRUSTED_PROXIES=127.0.0.1,::1

# ============================================
# API KEYS & INTEGRATIONS
# ============================================
# Add any additional API keys or integration tokens here

